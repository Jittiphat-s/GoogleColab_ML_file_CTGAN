        "\n",
        "    s = x.strip()\n",
        "\n",
        "    # remove encoding noise เช่น เธ\n",
        "    s = re.sub(r\"[^\\x00-\\x7F]+\", \" \", s)\n",
        "\n",
        "    # remove parentheses content\n",
        "    s = re.sub(r\"\\(.*?\\)\", \"\", s)\n",
        "\n",
        "    # collapse spaces\n",
        "    s = re.sub(r\"\\s+\", \" \", s)\n",
        "\n",
        "    return s.strip()\n"
      ]
