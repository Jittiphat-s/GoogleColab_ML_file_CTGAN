        "# ✅ Filtering IPD\n",
        "df_cul_ipd = apply_filter_sir(df_cul_ipd)\n",
        "\n",
        "# ✅ Filtering OPD\n",
        "df_cul_opd = apply_filter_sir(df_cul_opd)\n",
