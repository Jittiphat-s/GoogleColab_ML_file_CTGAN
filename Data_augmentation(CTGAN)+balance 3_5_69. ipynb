        "def extract_specimen_from_comment(text):\n",
        "    if not isinstance(text, str):\n",
        "        return None\n",
        "    match = re.search(r\"@Lab Comment:\\s*([A-Za-z0-9\\- ]+)\", text)\n",
        "    if match:\n",
        "        value = match.group(1).strip().lower()\n",
        "        if value and value != \"-\" and len(value) > 2:\n",
        "            return value\n",
        "    return None\n"
      ]
